generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── NextAuth required models ─────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Application models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // 'owner' | 'allowed' | 'pending' | 'denied'
  role          String    @default("pending")
  createdAt     DateTime  @default(now())

  // Daily LLM scan quota — reset by /api/cron/reset-quotas
  dailyScansUsed   Int      @default(0)
  dailyScansLimit  Int      @default(20)
  lastQuotaResetAt DateTime @default(now())

  /// When the user accepted the beta disclaimer (educational ideas, not
  /// financial advice). Null = not yet accepted; the Ideas tab (Phase 1) and
  /// the acceptance banner key off this. Client-beta Phase 0.3.
  disclaimerAcceptedAt DateTime?

  // ── Feature 5 + 8: public profile + leaderboard ───────────────────────────
  // username is the URL handle (@handle in UI, stored without @). Lowercase
  // alphanumeric + underscore, 3-30 chars. Unique. Nullable so existing rows
  // and not-yet-claimed accounts coexist.
  username             String? @unique
  bio                  String? @db.VarChar(200)
  dashboardTagline     String? @db.VarChar(60)
  publicProfileEnabled Boolean @default(false)
  // Tier is COMPUTED from trade stats in lib/profile/composite.ts — not stored
  // as a column so it never goes stale. Cache it later if leaderboard reads
  // become a hot path.

  accounts            Account[]
  sessions            Session[]
  connection          SpreadsheetConnection?
  tradeRecords        TradeRecord[]
  watchlist           Watchlist[]
  // Soft daily reflection (formerly `JournalEntry`) — mood, sleep, notes.
  // Renamed in 2026-05 schema migration to make room for per-trade JournalEntry.
  dailyReflections    DailyReflection[]
  // Per-trade journal analysis (trade-analyser output home).
  tradeJournalEntries JournalEntry[]
  tradeJournalLogs    TradeJournalLog[]
  // Multi-broker (Phase 0+ feature, gated behind NEXT_PUBLIC_FEATURE_BROKER_JOURNAL).
  brokerAccounts      UserBrokerAccount[]
  brokerPresets       BrokerPreset[]
  bridgeToken         BrokerBridgeToken?
  csvImportMappings   CsvImportMapping[]
  // A-list strict-quality candidates (Phase 1 of pre-open CI revamp).
  aListCandidates     AListCandidate[]
  // Daily equity timeline (Phase 4 of pre-open CI revamp).
  equitySnapshots     EquitySnapshot[]
  // Daily-journal automation prefs (Doc URL + widget config). 2026-06.
  journalPref         JournalPref?
  // TradesViz-platform P0: strategy playbooks + goals (P1/P4 build on these).
  playbooks           Playbook[]
  goals               Goal[]
}

model SpreadsheetConnection {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  spreadsheetId String
  sheetTab      String    @default("T.Journal [JS]")
  headerRow     Int       @default(14)
  dateCol       Int       @default(1) // 0-indexed; col B = 1. Editable in UI if auto-detect fails.
  colMap        Json      @default("{}") // { ticker, date, buyPrice, qty, pnl, exitPrice, side, fees, notes }
  lastSyncedAt  DateTime?
  // Single fixed USD→base rate the sheet uses to convert P&L/position to MYR.
  // Reverse it (÷ rate) to recover USD for sheet-only trades. Auto-detected from
  // broker-reconciled trades (lib/currency.ts detectFixedRate), editable in Settings.
  fixedFxRate   Decimal?  @db.Decimal(12, 6)
  createdAt     DateTime  @default(now())

  trades TradeRecord[]
}

// ── JournalPref (NEW 2026-06) — daily-journal automation prefs ───────────────
// Per-user singleton: the Google Doc URL the daily journal auto-writes to, the
// widget toggles (morning brief / market brief / high-impact news / trade
// entries / reflection), and an optional custom default template (Markdown).
model JournalPref {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyDocUrl     String?
  widgetPrefs     Json     @default("{}")
  defaultTemplate String?  @db.Text
  autoWrite       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── TradeRecord (formerly `Trade`) ───────────────────────────────────────────
//
// Schema rename, NOT a Postgres table rename. `@@map("Trade")` keeps the
// existing table in place so all historical data and indexes stay valid.
// All 16 API/lib files updated 2026-05 to use `prisma.tradeRecord`.
//
// Position lifecycle row: one TradeRecord per "trade" (entry + up to 3 trims
// + final exit). TradeFill is the raw audit log of every broker fill — see
// the `fills` relation below.
//
model TradeRecord {
  id           String                 @id @default(cuid())
  userId       String
  // connectionId becomes NULLABLE — manual / bridge / CSV trades don't have a
  // SpreadsheetConnection. Set when source = 'SHEET'.
  connectionId String?
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   SpreadsheetConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  // ── NEW (2026-05): multi-broker fields ───────────────────────────────────
  // 'SHEET' | 'MANUAL' | 'BRIDGE' | 'CSV' — kept as String for codebase
  // consistency (existing role/signal columns also use String).
  source          String             @default("SHEET")
  // Nullable: legacy sheet trades have no broker account; new entries do.
  brokerAccountId String?
  brokerAccount   UserBrokerAccount? @relation(fields: [brokerAccountId], references: [id], onDelete: SetNull)
  // Sub-day precision execution time. tradeDate is kept for date-based grouping
  // and matches existing UI; executedAt is the precise fill timestamp from
  // bridge data. For manual entries, executedAt mirrors tradeDate + 09:30 ET.
  executedAt      DateTime?
  // Used to de-dupe bridge syncs. Bridge sends broker's order/deal id.
  brokerOrderId   String?

  // ── Core execution fields (existing) ─────────────────────────────────────
  ticker    String
  tradeDate DateTime?
  buyPrice  Decimal?  @db.Decimal(12, 4)
  quantity  Decimal?  @db.Decimal(12, 2)
  pnl       Decimal?  @db.Decimal(12, 2) // NULL = open trade
  exitPrice Decimal?  @db.Decimal(12, 4)
  side      String? // "Long" | "Short"
  fees      Decimal?  @db.Decimal(12, 2)
  notes     String?
  /// User-authored trade thesis/reflection. Kept separate from imported or
  /// bridge-generated notes and included in every in-page AI coaching run.
  thoughts  String?   @db.Text
  /// TradesViz-platform P0 (for the P1 trade-detail page): free-form labels
  /// (["gap-up","earnings"]), chart/screenshot URLs, and mistake
  /// classifications (["chased","moved-stop"]). All string arrays.
  tags        Json?
  screenshots Json?
  mistakes    Json?
  rawRow    Json // full row stored for re-parsing without re-fetching
  syncedAt  DateTime  @default(now())

  // Pre-trade plan columns (mapped from Google Sheet)
  proposedEntry Decimal? @db.Decimal(12, 4) // "Proposed Buy Price"
  proposedSL    Decimal? @db.Decimal(12, 4) // "Proposed SL Price"
  proposedTP    Decimal? @db.Decimal(12, 4) // "Proposed TP Price"
  rrr           Decimal? @db.Decimal(6, 2) // "RRR"
  riskPct       Decimal? @db.Decimal(6, 2) // "Risk (%)"
  rewardPct     Decimal? @db.Decimal(6, 2) // "Reward (%)"
  positionPct   Decimal? @db.Decimal(6, 2) // "Position (%)"
  currency      String?
  // ── Currency normalization (2026-06) — everything reported in USD ─────────
  // `currency` is the raw sheet label; `currencyCode` is the resolved ISO code;
  // `pnlUsd` is P&L in USD via the authority ladder in lib/currency.ts; `fxRate`
  // is the rate applied (if any); `pnlSource` ∈ broker | sheet-fixed-rate |
  // native-usd | unconverted. See log.md 2026-06 currency-truth migration.
  currencyCode  String?
  pnlUsd        Decimal? @db.Decimal(12, 2)
  fxRate        Decimal? @db.Decimal(12, 6)
  pnlSource     String?
  platform      String?
  industry      String?
  strategy      String?

  // State synced from spreadsheet (col AO): CLOSE | OPEN | SEMI-OPEN | PLANNING
  state String?

  // AI verdict cache (latest run)
  verdict            Json?
  verdictScore       Float?
  verdictGeneratedAt DateTime?

  verdictHistory TradeVerdictHistory[]
  journalEntry   JournalEntry?
  journalLogs    TradeJournalLog[]
  fills          TradeFill[]

  @@unique([brokerAccountId, brokerOrderId], name: "brokerAccount_brokerOrderId")
  @@index([userId, tradeDate])
  @@index([brokerAccountId, executedAt])
  @@index([source])
  @@map("Trade")
}

model TradeVerdictHistory {
  id             String      @id @default(cuid())
  tradeId        String
  trade          TradeRecord @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  ticker         String
  tradeDate      DateTime?
  model          String
  provider       String
  // 'trader-debate' (6-persona scorer) | 'agent-pipeline' (5-agent role-based)
  style          String      @default("trader-debate")
  // 'day-0' (initial scoring at journal time) | 'day-14-rescore' (heuristic outcome check)
  kind           String      @default("day-0")
  // Populated only when kind='day-14-rescore'. Shape:
  // { actual_close_d14, actual_pct_move_14d, actual_high_d14, actual_low_d14,
  //   predicted_exit_price, predicted_stop_price, match_grade ('A'|'B'|'C'),
  //   match_notes, drift_detected, wiki_changes_suggested[] }
  outcomeMetrics Json?
  verdict        Json
  score          Float?
  createdAt      DateTime    @default(now())

  @@index([tradeId])
  @@index([ticker, tradeDate])
  @@index([kind, createdAt]) // for cron: find day-0 verdicts 14+ days old
  @@index([tradeId, kind]) // for cron: check if day-14-rescore already exists
}

/// Append-only user-authored notes for a trade. The current editable reflection
/// remains on TradeRecord.thoughts for prompt construction; this table preserves
/// the sequence so the detail page can show a real journal timeline.
model TradeJournalLog {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeId   String
  trade     TradeRecord @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  kind      String      @default("THOUGHT")
  body      String      @db.Text
  createdAt DateTime    @default(now())

  @@index([tradeId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ── Phase 4: Multi-tenant scanner + agent pipeline ───────────────────────────

model Watchlist {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker  String
  addedAt DateTime @default(now())

  @@unique([userId, ticker])
  @@index([userId])
  @@index([ticker])
}

/// Market breadth snapshot — DB-backed (push), so it updates without a git
/// commit + Vercel rebuild. Powered by the TradingView scanner aggregate-count
/// endpoint (see src/server/breadth-scanner.ts), refreshed by /api/breadth/refresh
/// which any scheduler can trigger (Vercel cron, external uptime cron, bridge
/// daemon — redundant triggers = reliability without checking if GH Actions ran).
///
/// One row per (bucketDate). Upserted — re-runs the same day overwrite.
/// `snapshot` holds the full BreadthSnapshot JSON (matches types/breadth.ts).
model MarketBreadthSnapshot {
  id          String   @id @default(cuid())
  /// UTC date this snapshot represents (one row per trading day).
  bucketDate  DateTime @db.Date
  /// Full BreadthSnapshot JSON (market, momentum, sectors, industries).
  snapshot    Json
  /// "tv-scanner" | "breadth_scan_py" | "breadth_fast_py" — provenance.
  source      String   @default("tv-scanner")
  refreshedAt DateTime @default(now())
  /// Wall-clock ms the refresh took (for monitoring scanner health).
  durationMs  Int?

  @@unique([bucketDate])
  @@index([refreshedAt(sort: Desc)])
}

/// Authoritative daily OHLCV bars pushed from the local moomoo OpenD / IBKR
/// bridge (P2). The track-positions cron prefers these over the cloud Yahoo/Stooq
/// fallback when they are fresh, so MFE/MAE/stops are computed from the same
/// price basis the broker fills are in. One row per (ticker, date).
model BrokerDailyBar {
  id        String   @id @default(cuid())
  ticker    String // plain uppercase ticker, e.g. "MU"
  date      DateTime @db.Date
  open      Decimal? @db.Decimal(14, 4)
  high      Decimal? @db.Decimal(14, 4)
  low       Decimal? @db.Decimal(14, 4)
  close     Decimal? @db.Decimal(14, 4)
  volume    BigInt?
  source    String   @default("opend")
  fetchedAt DateTime @default(now())

  @@unique([ticker, date])
  @@index([ticker, date(sort: Desc)])
}

/// Daily TV screener snapshot — DB-backed (push) so it refreshes reliably via
/// Vercel cron hitting /api/screeners/refresh (TradingView scanner, proven to
/// work from Vercel), instead of GitHub Actions cron which skipped intraday and
/// left the screener stale during market hours. Mirrors MarketBreadthSnapshot.
model ScreenerSnapshot {
  id          String   @id @default(cuid())
  bucketDate  DateTime @db.Date
  /// Full tv_screeners.json shape: { fetched_at, market_was_open, screeners[] }.
  snapshot    Json
  source      String   @default("tv-scanner")
  refreshedAt DateTime @default(now())
  durationMs  Int?

  @@unique([bucketDate])
  @@index([refreshedAt(sort: Desc)])
}

// ── Phase 5: Unified Conviction Desk — brief cache + live quotes ──────────────

model MorningBriefCache {
  id             String   @id @default(cuid())
  bucketAt       DateTime
  provider       String
  htmlBody       String   @db.Text
  verdictJson    Json?
  structuredJson Json?
  generatedAt    DateTime @default(now())
  generatedBy    String
  inputHash      String
  tokensIn       Int?
  tokensOut      Int?
  costUsd        Decimal? @db.Decimal(10, 6)
  errorMsg       String?

  @@unique([bucketAt, provider])
  @@index([provider, bucketAt(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
}

model WikiAudit {
  operatorLabel String   @default("JS")
  period        String // YYYY-MM
  markdown      String   @db.Text
  parsedJson    Json
  sourcePath    String?
  sizeBytes     Int?
  ingestedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@id([operatorLabel, period])
  @@index([period(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model WikiTradeVerdict {
  id              String   @id @default(cuid())
  operatorLabel   String   @default("JS")
  /// "journal" (entered trade — rolled up into the monthly audit),
  /// "analysis" (chat ad-hoc score — kept in Analysis History tab).
  /// Screener picks live in WikiScreenerPick, not here.
  intent          String   @default("journal")
  tradeDate       DateTime @db.Date
  ticker          String
  year            String
  day0Json        Json?
  day14Json       Json?
  day0SourcePath  String?
  day14SourcePath String?
  ingestedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([operatorLabel, tradeDate, ticker])
  @@index([ticker, tradeDate(sort: Desc)])
  @@index([tradeDate(sort: Desc)])
  @@index([intent, tradeDate(sort: Desc)])
}

/// Daily screener snapshot. Lightweight — no full LLM verdict per ticker.
/// Captures "what the screener flagged on date X" so we can compute
/// conversion rate (screener → journaled trade) and surface missed setups.
model WikiScreenerPick {
  id                  String   @id @default(cuid())
  operatorLabel       String   @default("JS")
  /// The day the screener was run, not the trade entry date.
  pickDate            DateTime @db.Date
  ticker              String
  /// Optional: setup_classification guess (e.g. "EP-FRESH", "BO-CB").
  setupClassification String?
  /// Which screener / criteria matched. e.g. "qullamaggie-ep", "rs-leaders".
  screenSource        String
  /// Free-form notes — RVOL, sector, why it caught your eye, etc.
  notes               String?  @db.Text
  /// Optional: source URL (TradingView screenshot, Finviz, etc.)
  sourceUrl           String?
  /// Optional: when a screener pick later gets journaled, link the Trade.id
  /// here so conversion rate can be computed.
  convertedTradeId    String?
  ingestedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([operatorLabel, pickDate, ticker, screenSource])
  @@index([operatorLabel, pickDate(sort: Desc)])
  @@index([ticker, pickDate(sort: Desc)])
  @@index([screenSource, pickDate(sort: Desc)])
}

/// A-list candidate — daily strict-quality picks that meet ALL three filters:
///   1. DeepSeek score >= 80
///   2. Verdict == "GO"
///   3. RVOL >= 1.5x
///
/// Promoted automatically from the pre-open brief. Tracked across 14 sessions
/// with day-0 entry thesis and day-14 outcome (MFE / MAE / outcome score).
/// Surfaced on the dedicated /a-list page with filters by date / sector /
/// setup / status / score.
///
/// Differs from `WikiScreenerPick` which is a softer log of every flagged ticker.
/// A-list is the strict subset worth actively monitoring.
///
/// Multi-tenant: keyed by userId. Each user has their own personal A-list
/// and callers only read rows for their own userId. Shared market-wide REC
/// picks are delivered through shared market-data routes, not owner fallback.
model AListCandidate {
  id                  String   @id @default(cuid())
  /// Owner of this candidate. FK to User.id. CI ingest must resolve to an
  /// owner-role user (today: derived from BRIEF_INGEST_KEY; future: scoped per
  /// user-key). Backwards-compat field `operatorLabel` is kept as a denormalised
  /// human label ("JS") for log / display purposes.
  userId              String
  operatorLabel       String   @default("JS")
  /// Date the candidate was promoted (= brief date, pre-open).
  pickDate            DateTime @db.Date
  ticker              String
  /// Setup classification at pick time (BO-CB, EP-FRESH, PB-21EMA, etc.).
  setupClassification String?
  /// Which screener URL surfaced this (e.g. "best-winners", "vcp-200ma", "premarket").
  screenSource        String?
  sector              String?
  industry            String?
  /// Promotion source — auto from brief, or manual override from /a-list page.
  /// "AUTO" (filter passed) | "MANUAL" (user added/promoted)
  source              String   @default("AUTO")

  // ── Day-0 entry proposal (from brief) ──────────────────────────────────
  entryZone         Decimal?  @db.Decimal(12, 4)
  stop              Decimal?  @db.Decimal(12, 4)
  target            Decimal?  @db.Decimal(12, 4)
  rrr               Decimal?  @db.Decimal(6, 2)
  /// 0-100 Conviction composite at pick day (Setup/40+Entry/30+Theme/20+Sentiment/10).
  day0Score         Int?
  /// "GO" | "WAIT" | "PASS" (GO >= 75).
  day0Verdict       String?
  day0Rvol          Decimal?  @db.Decimal(6, 2)
  day0Thesis        String?   @db.Text
  /// Trader-style lens that fits best (e.g. "@Qullamaggie", "@markminervini").
  day0TraderLens    String?
  /// Conviction sub-scores at pick day (wiki/trader-styles.md). Null for
  /// brief-sourced picks that don't carry the deterministic breakdown.
  setupScore        Int?
  entryScore        Int?
  themeScore        Int?
  sentimentScore    Int?
  /// Best-match persona for the setup (deterministic heuristic at pick time;
  /// the R4 multi-agent refines it on triggered picks).
  championPersona   String?
  /// Link to the brief that promoted this candidate (frozen reference).
  day0BriefBucketAt DateTime?
  day0BriefProvider String?
  /// Price at pick close (or pre-mkt if pick happened pre-mkt).
  day0Price         Decimal?  @db.Decimal(12, 4)
  /// Market backdrop at entry day (lib/market-context.ts): { spyChg, qqqChg,
  /// breadthAdvance, breadthDecline, fearGreed, fearGreedLabel, asOf }. Lets the
  /// page separate "the pick" from "the tape" (entry vs exit).
  day0Market        Json?

  // ── Day-14 outcome (computed on day 14 via cron) ───────────────────────
  /// Highest close above entry over 14 sessions.
  day14Mfe          Decimal?  @db.Decimal(12, 4)
  /// Lowest close below entry over 14 sessions.
  day14Mae          Decimal?  @db.Decimal(12, 4)
  /// MFE in R units (Mfe / risk where risk = entry - stop).
  day14MfeR         Decimal?  @db.Decimal(6, 2)
  /// MAE in R units.
  day14MaeR         Decimal?  @db.Decimal(6, 2)
  /// 0-10 outcome score per the audit rubric.
  day14Score        Decimal?  @db.Decimal(4, 2)
  /// Brief AI commentary on the outcome.
  day14Verdict      String?   @db.Text
  /// Re-run of the 7 trader-style scorecard at day-14.
  day14TraderScores Json?
  /// Did price hit target / stop / neither.
  day14Outcome      String? // "HIT_TARGET" | "STOPPED_OUT" | "PARTIAL" | "FADE" | "DRIFT"
  day14ComputedAt   DateTime?

  // ── HELD lane (bought position) — Phase 2-3 (2026-06) ─────────────────────
  // A row can be REC-only (brief pick), HELD-only (off-book buy), or REC+HELD
  // (on-book). The score>=80 / GO / RVOL>=1.5 bar only gates the REC badge;
  // HELD membership is "a real fill landed in the account" — ungated. The entry
  // grade is a learning overlay, not an admission test. See dashboard redesign memo.
  /// True when this row tracks a real position you hold/held.
  isHeld            Boolean   @default(false)
  /// Open Position this row tracks (if still open).
  heldPositionId    String?
  /// Reconciled TradeRecord lifecycle (entry->exit), if linked.
  heldTradeRecordId String?
  /// First BUY fill time (= day-0 for HELD tracking).
  entryFillAt       DateTime?
  /// Realized entry (avg cost across BUY fills).
  entryAvgCost      Decimal?  @db.Decimal(12, 4)
  /// Shares held (peak) for sizing.
  heldQty           Decimal?  @db.Decimal(18, 4)
  /// on-book = matched a REC pick near entry; false = off-book / freelance.
  onBook            Boolean?
  /// Entry grade vs the A-list bar: "A" | "B" | "C".
  entryGrade        String?
  /// { score, rvol, setup, verdict, passedBar, vsBarNotes } snapshot at entry.
  entryGradeJson    Json?

  // ── 1R bases (BOTH, per redesign) ─────────────────────────────────────────
  /// 1R using the stop you logged at entry: (entry - loggedStop), $/share.
  rUnitLogged       Decimal?  @db.Decimal(12, 4)
  /// 1R using the wiki ATR-floor stop (1.5xATR or 5d-low, wider; 1.2xATR PB-21EMA).
  rUnitAtr          Decimal?  @db.Decimal(12, 4)
  /// The ATR-floor stop price used for rUnitAtr.
  atrFloorStop      Decimal?  @db.Decimal(12, 4)

  // ── Savings metrics (computed at exit / day-14) ───────────────────────────
  /// Realized R achieved from actual exits/trims (+ profit / - loss).
  realizedRLogged   Decimal?  @db.Decimal(6, 2)
  realizedRAtr      Decimal?  @db.Decimal(6, 2)
  /// Realized-vs-full-R savings = full -1R loss minus actual loss ($ and R).
  saveRealizedUsd   Decimal?  @db.Decimal(12, 2)
  saveRealizedR     Decimal?  @db.Decimal(6, 2)
  /// Soft-tranche (8EMA partial + 21EMA full) exit prices.
  soft8emaExit      Decimal?  @db.Decimal(12, 4)
  soft21emaExit     Decimal?  @db.Decimal(12, 4)
  /// Soft-vs-Hard savings = riding to -1R hard stop minus soft-tranche exit.
  saveSoftVsHardUsd Decimal?  @db.Decimal(12, 2)
  saveSoftVsHardR   Decimal?  @db.Decimal(6, 2)
  /// When/whether the hard stop was breached in-window.
  hardStopHitAt     DateTime?
  hardStopHitBasis  String?   // "LOGGED" | "ATR" | "BOTH"
  /// Market backdrop captured at exit (broker exit / day-14 terminal). Same shape
  /// as day0Market — pair them to read "was it the pick or the tape?".
  exitMarket        Json?

  // ── Status lifecycle ────────────────────────────────────────────────────
  /// "ACTIVE" | "EXPIRED" | "HIT_TARGET" | "STOPPED_OUT" | "MANUALLY_CLOSED" | "CONVERTED"
  status           String  @default("ACTIVE")
  /// If user actually entered the trade, link to the TradeRecord.
  convertedTradeId String?

  // ── Entry-trigger lifecycle (R3.2; REC picks) ─────────────────────────────
  /// "ARMED" | "TRIGGERED" | "INVALIDATED" | "EXPIRED" — per wiki/entry-methods
  /// per-setup trigger rules. Computed by the daily tracker from shared market
  /// data; the "should I take it" signal. Null for HELD (already entered).
  triggerState     String?
  triggerStateAt   DateTime?
  triggerReason    String?

  // ── 3-lot scale-out simulation (computed on TRIGGERED; lib/alist-tranche-sim) ──
  /// TrancheSim JSON: entry=trigger-day close, stop=LoD/ATR-floor, lots at
  /// +1R/+2R/+3R with breakeven raise after T1. Answers "would the trigger
  /// have paid before the stop, selling in three portions?"
  trancheSim       Json?

  // ── Multi-agent Conviction verdict (R4; runs once on TRIGGERED) ────────────
  /// LLM Conviction breakdown + per-component reasoning (ConvictionAnalysis).
  agentConviction   Json?
  /// Moderator decision: "ENTER" | "WAIT" | "PASS".
  agentVerdict      String?
  agentConvictionAt DateTime?

  // ── Free-form ───────────────────────────────────────────────────────────
  notes String? @db.Text
  tags  Json? // e.g. ["earnings", "AI-infra", "post-gap-VCP"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyTracks PositionDailyTrack[]

  @@unique([userId, pickDate, ticker])
  @@index([userId, pickDate(sort: Desc)])
  @@index([ticker, pickDate(sort: Desc)])
  @@index([status, pickDate(sort: Desc)])
  @@index([day14Outcome, pickDate(sort: Desc)])
  @@index([sector, pickDate(sort: Desc)])
  @@index([isHeld, pickDate(sort: Desc)])
  @@index([heldPositionId])
}

/// PositionDailyTrack — one row per tracked A-list ticker per trading day, for
/// the ~14 trading days after day-0. Captures the price path (OHLC + EMA8/EMA21
/// + ATR14) and per-session flags so the tracker can compute WHEN the hard stop
/// / 8EMA / 21EMA broke, and from that the Realized-vs-R and Soft-vs-Hard
/// savings. Appended by the post-close daily cron. Phase 2-3 (2026-06).
model PositionDailyTrack {
  id          String         @id @default(cuid())
  candidateId String
  candidate   AListCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  /// Trading-day index since day-0 (0..14).
  dayIndex    Int
  sessionDate DateTime @db.Date

  open   Decimal? @db.Decimal(12, 4)
  high   Decimal? @db.Decimal(12, 4)
  low    Decimal? @db.Decimal(12, 4)
  close  Decimal? @db.Decimal(12, 4)
  volume BigInt?
  /// Relative volume vs 50-day average (for trigger volume-expansion checks).
  rvol   Decimal? @db.Decimal(6, 2)
  ema8   Decimal? @db.Decimal(12, 4)
  ema21  Decimal? @db.Decimal(12, 4)
  atr14  Decimal? @db.Decimal(12, 4)

  // Per-session flags, evaluated on this session's close.
  closeBelow8ema    Boolean @default(false)
  closeBelow21ema   Boolean @default(false)
  hardStopHitLogged Boolean @default(false)
  hardStopHitAtr    Boolean @default(false)

  /// Running MFE/MAE in R (vs entry, logged 1R base) through this session.
  runMfeR Decimal? @db.Decimal(6, 2)
  runMaeR Decimal? @db.Decimal(6, 2)

  createdAt DateTime @default(now())

  @@unique([candidateId, sessionDate])
  @@index([candidateId, dayIndex])
}

// (BriefSnapshot dropped 2026-06-01 — unused; the A-list keeps denormalised
//  day0Brief* refs and MorningBriefCache holds the live brief. Re-add if the
//  auto-journal ever needs an immutable per-entry frozen brief.)

/// Daily equity snapshot — captured by the dashboard-bridge daemon when it
/// runs on Jie's PC (typically every 60s during MYT daytime). One row per
/// (userId, brokerAccountId, snapshotDate). Latest snapshot per day wins.
///
/// Powers the /equity timeline page (Phase 6): plots daily equity curve,
/// highlights drawdown periods, drills into per-trade attribution.
///
/// Multi-currency: account stores values in the broker's local currency
/// (totalAssets / cash / marketVal). currencyCode lets the dashboard apply
/// FX conversion at display time if needed.
model EquitySnapshot {
  id              String   @id @default(cuid())
  userId          String
  brokerAccountId String
  /// Calendar date of the snapshot (UTC). Stored as Date for clean grouping
  /// in queries like "give me all snapshots from May 2026".
  snapshotDate    DateTime @db.Date
  /// Precise capture time (UTC). Latest capture for a given snapshotDate is
  /// considered authoritative for the daily equity curve.
  capturedAt      DateTime @default(now())

  // ── Broker-reported values (all in the account's local currency) ───────
  totalAssets     Decimal  @db.Decimal(18, 4)
  cash            Decimal  @db.Decimal(18, 4)
  marketVal       Decimal  @db.Decimal(18, 4)
  /// Sum of unrealized P/L across all current positions.
  unrealizedPl    Decimal? @db.Decimal(18, 4)
  /// Today's realized P/L (closed trades since market open).
  realizedPlDay   Decimal? @db.Decimal(18, 4)
  /// Convenience: % change vs prior-day totalAssets. Computed daemon-side.
  equityPctChange Decimal? @db.Decimal(8, 4)
  /// Account currency (USD, HKD, etc.) — matches the local moomoo account.
  currencyCode    String   @default("USD")

  /// "moomoo" | "manual" | "csv" — provenance for the row.
  source          String   @default("moomoo")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brokerAccountId, snapshotDate])
  @@index([userId, snapshotDate(sort: Desc)])
  @@index([brokerAccountId, snapshotDate(sort: Desc)])
}

// ── DailyReflection (formerly `JournalEntry`) ───────────────────────────────
//
// Soft daily reflection: mood, sleep, market conditions, free-form notes,
// chart links, attachments. One row per (user, entryDate).
//
// Renamed from `JournalEntry` in 2026-05 multi-broker schema migration so the
// `JournalEntry` model name could be repurposed for per-trade analysis.
// Postgres table also renamed from "JournalEntry" to "DailyReflection" so
// the new JournalEntry model can claim its own fresh table.
//
model DailyReflection {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate        DateTime @db.Date // YYYY-MM-DD, one per user per day
  moodEmoji        String? // single grapheme like "😊" — see lib/journal/mood.ts
  sleepHours       Decimal? @db.Decimal(4, 2) // 0.00–24.00
  marketConditions String? // free-text or one of the enum values in lib/journal/mood.ts
  notes            String?  @db.Text
  tvLinks          Json     @default("[]") // array of strings (TradingView or any URL)
  attachmentUrls   Json     @default("[]") // populated by Feature 7.2 — Vercel Blob URLs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, entryDate])
  @@index([userId, entryDate(sort: Desc)])
}

// ── JournalEntry (NEW 2026-05) — per-trade analysis ─────────────────────────
//
// One row per TradeRecord. This is the home for trade-analyser output:
// setup classification, priming pattern, 7-trader rubric scores, fundamental
// grade, evolution note, wiki references.
//
// Distinct from DailyReflection (which is the daily mood/sleep/notes layer).
// Distinct from TradeVerdictHistory (which is the multi-version AI scoring
// audit log — many rows per trade for re-scoring runs).
//
model JournalEntry {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeRecordId String      @unique
  tradeRecord   TradeRecord @relation(fields: [tradeRecordId], references: [id], onDelete: Cascade)

  // Setup classification (see skills/trade-analyser SKILL.md Step 2.5)
  setupType          String // EP-FRESH | POST-GAP-VCP | BO-VCP | BO-CB | PB-21EMA | MA-PULLBACK | POCKET-PIVOT | ORH-INTRADAY | PARABOLIC | EP-SECOND | CONTINUATION | OTHER
  primingPattern     String? // INSIDE-BAR | UPSIDE-REVERSAL | POSITIVE-EXPECTATION-BREAKER | TIGHT-SETUP-DAY | NONE
  setupJustification String? @db.Text // 1-2 sentence wiki-cited explanation

  // 7-trader rubric — { [traderName]: { entry, risk, setup, total, wouldEnter, why } }
  traderScores Json

  // Fundamental score (冷眼 A/B/C framework — see wiki/fundamental-analysis.md)
  fundamentalGrade String? // A | B | C
  fundamentalData  Json? // { growth, profitability, valuation, balanceSheet }

  compositeScore   Decimal @db.Decimal(4, 2) // 0.00–10.00
  bestStyleMatch   String? // trader name
  weakestDimension String? // explanation

  entryVerdict  String // GOOD | ACCEPTABLE | POOR
  evolutionNote String? @db.Text
  patternNote   String? @db.Text // vs last 5 trades — recurring weakness/improvement

  wikiRefs String[] // array of wiki paths consulted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

// ── BrokerPreset (NEW 2026-05) ───────────────────────────────────────────────
//
// Fee formula presets. Built-in presets seeded by migration; users can clone
// and customise. feeFormula schema:
//   {
//     commission: { type: 'fixed'|'perShare'|'perTrade', value, minimum?, applyTo?: 'BUY'|'SELL'|'BOTH' },
//     secFee:     { type: 'perShare', value, minimum?, applyTo?: 'SELL' },
//     tafFee:     { type: 'perShare', value, minimum?, applyTo?: 'SELL' },
//     exchangeFee:{ type: 'perTrade', value, applyTo?: 'BUY'|'SELL'|'BOTH' }
//   }
//
model BrokerPreset {
  id         String   @id @default(cuid())
  // Globally unique name for built-ins; per-user-scoped for user clones.
  name       String
  region     String // 'US' | 'HK' | 'SG' | 'MY' | 'CN' | 'AU' | 'CA' | 'JP'
  currency   String // 'USD' | 'HKD' | 'SGD' | 'MYR' | ...
  feeFormula Json
  isBuiltIn  Boolean  @default(false)
  // userId is NULL for built-in presets, set for user-cloned ones.
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  accounts UserBrokerAccount[]

  @@unique([userId, name])
  @@index([isBuiltIn])
}

// ── UserBrokerAccount (NEW 2026-05) ─────────────────────────────────────────
//
// Links a User to a BrokerPreset and stores per-account metadata. A user may
// have multiple accounts (e.g. "Main margin", "IRA", "Paper trading").
// `brokerAccountId` is the external broker's own account ID (e.g. moomoo
// 286260077786655984 or IBKR U1234567) — only set for bridge/CSV sources.
//
model UserBrokerAccount {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  presetId        String
  preset          BrokerPreset @relation(fields: [presetId], references: [id], onDelete: Restrict)
  // User-defined display name, e.g. "Main margin", "IRA".
  alias           String
  // External broker's own account identifier (nullable for manual-only accounts).
  brokerAccountId String?
  // Multi-currency display preference for this account.
  displayCurrency String?
  isActive        Boolean      @default(true)
  isLive          Boolean      @default(false) // false = paper trading
  createdAt       DateTime     @default(now())

  positions    Position[]
  fills        TradeFill[]
  tradeRecords TradeRecord[]

  @@unique([userId, alias])
  @@index([userId])
}

// ── BrokerBridgeToken (NEW 2026-05) ─────────────────────────────────────────
//
// Per-user HMAC token for the local bridge daemon to authenticate against
// /api/bridge/sync. Phase 3 feature — schema landed in Phase 0 so the bridge
// can be developed in parallel.
//
// `tokenHash` is sha256(plaintext); plaintext is shown to the user ONCE on
// generation and never stored. Bridge stores plaintext in
// ~/.config/dashboard-bridge.toml (chmod 600).
//
model BrokerBridgeToken {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique
  // Optional label so a user with multiple machines knows which token is which.
  label         String?
  createdAt     DateTime  @default(now())
  lastHeartbeat DateTime?
  revokedAt     DateTime?

  @@index([lastHeartbeat])
}

// ── Position (NEW 2026-05) ──────────────────────────────────────────────────
//
// Current position snapshot per (brokerAccount, ticker). One row per held
// position. Refreshed by:
//   - Bridge sync (Phase 3): exact broker data, overwrites snapshot
//   - Manual entry: increments/decrements from TradeFill aggregation
//   - CSV import: same as manual, batched
//
// avgCost stored in the position's local currency (matches broker's reporting).
//
model Position {
  id              String            @id @default(cuid())
  brokerAccountId String
  brokerAccount   UserBrokerAccount @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)
  ticker          String // 'US.HUT', 'HK.00700', etc.
  qty             Decimal           @db.Decimal(18, 4)
  avgCost         Decimal           @db.Decimal(12, 4)
  currency        String // matches broker's local currency
  // Cached fields refreshed by MarketQuote join (so we don't recompute on every read)
  currentPrice    Decimal?          @db.Decimal(12, 4)
  marketValue     Decimal?          @db.Decimal(18, 4)
  unrealizedPl    Decimal?          @db.Decimal(18, 4)
  unrealizedPlPct Decimal?          @db.Decimal(8, 4)
  openedAt        DateTime
  lastFillAt      DateTime
  asOf            DateTime          @default(now())

  @@unique([brokerAccountId, ticker])
  @@index([brokerAccountId])
  @@index([ticker])
}

// ── TradeFill (NEW 2026-05) ─────────────────────────────────────────────────
//
// Immutable audit log of every broker fill. Distinct from TradeRecord (the
// mutable position-lifecycle row): one TradeRecord can have many TradeFills
// (entry + each trim + final exit).
//
// Populated by:
//   - Manual entry: 1 fill per saved trade
//   - Bridge sync: 1 fill per broker deal/execution event
//   - CSV import: 1 fill per CSV row
//
// brokerFillId is the broker's own fill/execution id — used to de-dupe
// re-imports and bridge re-syncs.
//
model TradeFill {
  id              String            @id @default(cuid())
  // Nullable: a fill exists in the bridge stream before a TradeRecord lifecycle
  // is associated (the reconciler links them later).
  tradeRecordId   String?
  tradeRecord     TradeRecord?      @relation(fields: [tradeRecordId], references: [id], onDelete: SetNull)
  brokerAccountId String
  brokerAccount   UserBrokerAccount @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)
  brokerFillId    String? // broker's deal_id / execId — null for manual entries
  ticker          String
  side            String // 'BUY' | 'SELL'
  qty             Decimal           @db.Decimal(18, 4)
  price           Decimal           @db.Decimal(12, 4)
  executedAt      DateTime
  fees            Decimal?          @db.Decimal(12, 4)
  currency        String?
  source          String // 'MANUAL' | 'BRIDGE' | 'CSV'
  createdAt       DateTime          @default(now())

  @@unique([brokerAccountId, brokerFillId], name: "brokerAccount_brokerFillId")
  @@index([brokerAccountId, executedAt(sort: Desc)])
  @@index([tradeRecordId])
  @@index([ticker, executedAt(sort: Desc)])
}

// ── CsvImportMapping (NEW 2026-05) ──────────────────────────────────────────
//
// Stores user-confirmed CSV column mappings per broker so re-imports don't
// require remapping each time. Keyed by (user, broker name).
//
model CsvImportMapping {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brokerName String // matches a BrokerPreset.name when possible, free text otherwise
  // Header → field name mapping, e.g. { "Symbol": "ticker", "Trade Date": "executedAt" }
  columnMap  Json
  dateFormat String? // e.g. 'MM/dd/yyyy'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, brokerName])
}

// ── LiveQuote (EXISTING — unchanged) ────────────────────────────────────────
//
// Brief tickers (SPY/QQQ/XLK/...). Upserted by morning-brief workflow.
// Kept separate from MarketQuote (portfolio prices) to preserve existing
// /api/live-quotes contracts and avoid the brief ever depending on a Position
// being open.
//
model LiveQuote {
  symbol     String   @id // 'SPY', 'QQQ', 'XLK', ...
  price      Decimal  @db.Decimal(12, 4)
  changePct  Decimal? @db.Decimal(8, 4)
  volume     BigInt?
  source     String // 'moomoo' | 'yahoo'
  observedAt DateTime
  ingestedAt DateTime @default(now())

  @@index([source, observedAt(sort: Desc)])
}

// ── MarketQuote (NEW 2026-05) ───────────────────────────────────────────────
//
// Shared price layer for portfolio tickers. Refreshed every 5 min by
// /api/cron/refresh-quotes worker — only fetches tickers currently held in
// at least one Position row (cost-controlled).
//
// Separate from LiveQuote because:
//   - LiveQuote is for the brief's small fixed ticker set
//   - MarketQuote covers the broader user-portfolio universe
//   - Different SLAs (brief: 1-min via push; portfolio: 5-min via yfinance)
//   - Different sources (LiveQuote: moomoo/yahoo; MarketQuote: yahoo/opend/byok)
//
/// Strategy playbook (TradesViz-platform P0 shell; P1 builds the UI). Rules is
/// a JSON checklist: [{ text, required }]. A trade tagged to a playbook can be
/// graded on rule adherence (planned-vs-actual, P1).
model Playbook {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  /// Optional setup class this playbook codifies (EP-FRESH, PB-21EMA, ...).
  setupClass String?
  rules      Json     @default("[]")
  notes      String?  @db.Text
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, archived])
}

/// Trading goal (TradesViz-platform P0 shell; P4 builds tracking + alerts).
/// kind: "PNL" | "MAX_DAILY_LOSS" | "MAX_DRAWDOWN" | "PROCESS" | "WIN_RATE".
model Goal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String
  label       String
  target      Decimal?  @db.Decimal(14, 2)
  unit        String? // "USD" | "MYR" | "R" | "%" | "count"
  periodStart DateTime?
  periodEnd   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, active])
}

model MarketQuote {
  symbol     String   @id // 'US.HUT', 'HK.00700', etc.
  price      Decimal  @db.Decimal(12, 4)
  changePct  Decimal? @db.Decimal(8, 4)
  prevClose  Decimal? @db.Decimal(12, 4)
  dayHigh    Decimal? @db.Decimal(12, 4)
  dayLow     Decimal? @db.Decimal(12, 4)
  volume     BigInt?
  source     String // 'yahoo' | 'opend' | 'polygon' | 'iex'
  observedAt DateTime
  ingestedAt DateTime @default(now())

  @@index([source, observedAt(sort: Desc)])
  @@index([observedAt(sort: Desc)])
}
