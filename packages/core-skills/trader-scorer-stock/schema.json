{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "input": {
    "type": "object",
    "properties": {
      "stock_context": { "type": "string", "description": "Pre-formatted multi-line summary built from yahoo-finance2 quoteSummary" },
      "display": {
        "type": "object",
        "description": "Raw display fields used to seed the JSON example so the LLM does not invent ticker metadata",
        "properties": {
          "name": { "type": "string" },
          "sector": { "type": ["string", "null"] },
          "industry": { "type": ["string", "null"] },
          "exchange": { "type": ["string", "null"] },
          "currentPrice": { "type": ["number", "null"] },
          "changePct": { "type": ["number", "null"] },
          "week52Low": { "type": ["number", "null"] },
          "week52High": { "type": ["number", "null"] },
          "analystPT": { "type": ["number", "null"] },
          "earningsDate": { "type": ["string", "null"] },
          "earningsDays": { "type": ["number", "null"] },
          "marketCap": { "type": "string" },
          "revenueTtm": { "type": "string" },
          "grossMarginPct": { "type": ["number", "null"] },
          "trailingEps": { "type": ["number", "null"] },
          "forwardEps": { "type": ["number", "null"] },
          "dividendYieldPct": { "type": ["number", "null"] }
        },
        "required": ["name", "marketCap", "revenueTtm"]
      }
    },
    "required": ["stock_context", "display"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "name": { "type": "string" },
      "sector": { "type": "string" },
      "industry": { "type": "string" },
      "exchange": { "type": "string" },
      "price": { "type": ["number", "null"] },
      "price_change_pct": { "type": ["number", "null"] },
      "week52_low": { "type": ["number", "null"] },
      "week52_high": { "type": ["number", "null"] },
      "analyst_pt": { "type": ["number", "null"] },
      "earnings_date": { "type": "string" },
      "earnings_days": { "type": ["number", "null"] },
      "market_cap": { "type": "string" },
      "revenue_ttm": { "type": "string" },
      "gross_margin_pct": { "type": ["number", "null"] },
      "trailing_eps": { "type": ["number", "null"] },
      "forward_eps": { "type": ["number", "null"] },
      "dividend_yield_pct": { "type": ["number", "null"] },
      "eli12": { "type": "array", "items": { "type": "string" }, "minItems": 0, "maxItems": 3 },
      "professional_summary": { "type": "string" },
      "hot_theme": { "type": ["string", "null"] },
      "catalysts": { "type": "array", "items": { "type": "string" } },
      "significant_fundamentals": { "type": "array", "items": { "type": "string" } },
      "recent_events": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": ["string", "null"] },
            "type": { "type": "string" },
            "summary": { "type": "string" },
            "source": { "type": ["string", "null"] },
            "major_mover": { "type": "boolean" }
          },
          "required": ["date", "type", "summary", "source", "major_mover"]
        }
      },
      "insider_institutional_activity": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": ["string", "null"] },
            "party": { "type": "string" },
            "action": { "type": "string" },
            "detail": { "type": "string" }
          },
          "required": ["date", "party", "action", "detail"]
        }
      },
      "peer_sector_trend": {
        "type": "object",
        "properties": {
          "stock_trend_1m": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
          "sector_trend_1m": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
          "peers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ticker": { "type": "string" },
                "trend_1m": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
                "note": { "type": "string" }
              },
              "required": ["ticker", "trend_1m", "note"]
            }
          }
        }
      },
      "upcoming_catalysts": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": ["string", "null"] },
            "type": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["date", "type", "description"]
        }
      },
      "analyst_target_changes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": ["string", "null"] },
            "firm": { "type": ["string", "null"] },
            "change": { "type": "string" }
          },
          "required": ["date", "firm", "change"]
        }
      },
      "big_move_reasons": { "type": "array", "items": { "type": "string" } },
      "medical_biotech_risk": { "type": "string" },
      "unverified_flags": { "type": "array", "items": { "type": "string" } },
      "trader_analysis": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "handle": { "type": "string" },
            "score": { "type": "number", "minimum": 1, "maximum": 10 },
            "verdict": { "type": "string", "enum": ["STRONG BUY", "BUY", "HOLD", "AVOID", "STRONG AVOID"] },
            "note": { "type": "string" }
          },
          "required": ["handle", "score", "verdict", "note"]
        }
      },
      "entry_plan": {
        "type": "object",
        "properties": {
          "zone": { "type": "string" },
          "stop": { "type": "string" },
          "target": { "type": "string" },
          "risk_reward": { "type": "number" },
          "batches": { "type": "string" }
        }
      },
      "bulls": { "type": "array", "items": { "type": "string" } },
      "bears": { "type": "array", "items": { "type": "string" } },
      "composite_score": { "type": "number", "minimum": 1, "maximum": 10 },
      "composite_verdict": { "type": "string", "enum": ["STRONG BUY", "BUY", "HOLD", "AVOID", "STRONG AVOID"] },
      "composite_note": { "type": "string" },
      "best_match_trader": { "type": "string" }
    },
    "required": ["name", "trader_analysis", "composite_score", "composite_verdict"]
  }
}
