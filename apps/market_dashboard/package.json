{
  "name": "market-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:market": "node scripts/sync-market-dashboard.mjs",
    "sync:wiki": "node scripts/sync-wiki.mjs",
    "sync:wiki:post": "node scripts/sync-wiki.mjs --post",
    "sync:wiki:dry": "node scripts/sync-wiki.mjs --dry-run",
    "wiki:refresh": "node scripts/refresh-wiki-audits.mjs",
    "wiki:refresh:post": "npm run wiki:refresh && npm run sync:wiki:post",
    "wiki:screener:push": "node -e \"const {execSync}=require('node:child_process');const cwd=process.env.JIE_WIKI_ROOT||process.env.LLM_TRADERS_WIKI_ROOT||'../../../jie_wiki';for(const op of ['JS','XX']){execSync(`python scripts/push_screener_picks.py --post --journal-user ${op} --min-score 60`,{cwd,stdio:'inherit'});}\"",
    "eval:trading-brief": "node scripts/eval-trading-brief.mjs",
    "eval:trading-brief:export-neon": "node --env-file=.env.local scripts/export-neon-trading-eval.mjs",
    "eval:trading-brief:neon": "npm run eval:trading-brief:export-neon && npm run eval:trading-brief -- --cases evals/trading-brief/generated/neon-golden-set.json --results evals/trading-brief/generated/neon-results.json --min-score 0.8",
    "breadth:tv": "node -e \"const {execSync}=require('node:child_process');execSync('python scripts/breadth_scan_tv.py --out-dir data',{cwd:'../market_dashboard_backend',stdio:'inherit'});\"",
    "breadth:opend": "node -e \"const {execSync}=require('node:child_process');execSync('python scripts/breadth_scan_opend.py --out-dir data',{cwd:'../market_dashboard_backend',stdio:'inherit'});\"",
    "breadth:opend:sector-cache": "node -e \"const {execSync}=require('node:child_process');execSync('python scripts/breadth_scan_opend.py --build-sector-cache --out-dir data',{cwd:'../market_dashboard_backend',stdio:'inherit'});\"",
    "skills:sync": "node ../../scripts/skill-sync.mjs",
    "skills:check": "node ../../scripts/check-skill-sync.mjs",
    "skills:check:strict": "node ../../scripts/check-skill-sync.mjs --strict",
    "dev": "next dev --turbopack",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/xai": "^1.0.14",
    "@auth/prisma-adapter": "^2.11.2",
    "@azure/cosmos": "^4.2.0",
    "@azure/storage-blob": "^12.26.0",
    "@prisma/client": "5.22.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "ai": "^4.3.19",
    "googleapis": "^126.0.1",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-textarea-autosize": "^8.5.6",
    "recharts": "^2.15.0",
    "shadcn": "^1.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "twitter-api-v2": "^1.18.2",
    "yahoo-finance2": "^2.9.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
