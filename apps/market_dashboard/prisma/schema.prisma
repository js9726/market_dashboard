generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── NextAuth required models ─────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Application models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // 'owner' | 'allowed' | 'pending' | 'denied'
  role          String    @default("pending")
  createdAt     DateTime  @default(now())

  // Daily LLM scan quota — reset by /api/cron/reset-quotas
  dailyScansUsed   Int      @default(0)
  dailyScansLimit  Int      @default(20)
  lastQuotaResetAt DateTime @default(now())

  accounts       Account[]
  sessions       Session[]
  connection     SpreadsheetConnection?
  trades         Trade[]
  watchlist      Watchlist[]
  scanResults    ScanResult[]
  journalEntries JournalEntry[]
}

model SpreadsheetConnection {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  spreadsheetId String
  sheetTab      String    @default("T.Journal [JS]")
  headerRow     Int       @default(14)
  dateCol       Int       @default(1) // 0-indexed; col B = 1. Editable in UI if auto-detect fails.
  colMap        Json      @default("{}") // { ticker, date, buyPrice, qty, pnl, exitPrice, side, fees, notes }
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())

  trades Trade[]
}

model Trade {
  id           String                @id @default(cuid())
  userId       String
  connectionId String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   SpreadsheetConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Core execution fields
  ticker    String
  tradeDate DateTime?
  buyPrice  Decimal?  @db.Decimal(12, 4)
  quantity  Decimal?  @db.Decimal(12, 2)
  pnl       Decimal?  @db.Decimal(12, 2) // NULL = open trade
  exitPrice Decimal?  @db.Decimal(12, 4)
  side      String?   // "Long" | "Short"
  fees      Decimal?  @db.Decimal(12, 2)
  notes     String?
  rawRow    Json // full row stored for re-parsing without re-fetching
  syncedAt  DateTime  @default(now())

  // Pre-trade plan columns (mapped from Google Sheet)
  proposedEntry Decimal? @db.Decimal(12, 4) // "Proposed Buy Price"
  proposedSL    Decimal? @db.Decimal(12, 4) // "Proposed SL Price"
  proposedTP    Decimal? @db.Decimal(12, 4) // "Proposed TP Price"
  rrr           Decimal? @db.Decimal(6, 2)  // "RRR"
  riskPct       Decimal? @db.Decimal(6, 2)  // "Risk (%)"
  rewardPct     Decimal? @db.Decimal(6, 2)  // "Reward (%)"
  positionPct   Decimal? @db.Decimal(6, 2)  // "Position (%)"
  currency      String?
  platform      String?
  industry      String?
  strategy      String?

  // State synced from spreadsheet (col AO): CLOSE | OPEN | SEMI-OPEN | PLANNING
  state String?

  // AI verdict cache (latest run)
  verdict            Json?
  verdictScore       Float?
  verdictGeneratedAt DateTime?

  verdictHistory TradeVerdictHistory[]

  @@index([userId, tradeDate])
}

model TradeVerdictHistory {
  id        String    @id @default(cuid())
  tradeId   String
  trade     Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  ticker    String
  tradeDate DateTime?
  model     String
  provider  String
  // 'trader-debate' (6-persona scorer) | 'agent-pipeline' (5-agent role-based)
  style     String    @default("trader-debate")
  // 'day-0' (initial scoring at journal time) | 'day-14-rescore' (heuristic outcome check)
  kind           String   @default("day-0")
  // Populated only when kind='day-14-rescore'. Shape:
  // { actual_close_d14, actual_pct_move_14d, actual_high_d14, actual_low_d14,
  //   predicted_exit_price, predicted_stop_price, match_grade ('A'|'B'|'C'),
  //   match_notes, drift_detected, wiki_changes_suggested[] }
  outcomeMetrics Json?
  verdict   Json
  score     Float?
  createdAt DateTime  @default(now())

  @@index([tradeId])
  @@index([ticker, tradeDate])
  @@index([kind, createdAt])  // for cron: find day-0 verdicts 14+ days old
  @@index([tradeId, kind])    // for cron: check if day-14-rescore already exists
}

// ── Phase 4: Multi-tenant scanner + agent pipeline ───────────────────────────

model Watchlist {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker  String
  addedAt DateTime @default(now())

  @@unique([userId, ticker])
  @@index([userId])
  @@index([ticker])
}

model ScanResult {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker     String
  // BUY | SELL | HOLD
  signal     String
  entry      Decimal? @db.Decimal(12, 4)
  stop       Decimal? @db.Decimal(12, 4)
  target     Decimal? @db.Decimal(12, 4)
  confidence Float?
  // { data: {...}, technical: {...}, chart: {...}, risk: {...}, moderator: {...} }
  agents     Json
  computedAt DateTime @default(now())
  expiresAt  DateTime

  @@index([userId, expiresAt])
  @@index([userId, ticker])
  @@index([ticker])
}

// ── Phase 5: Unified Conviction Desk — brief cache + live quotes ──────────────
//
// MorningBriefCache stores both the long-form HTML brief AND the structured
// trader-verdict JSON for a given 15-minute bucket × provider. Cadence:
//   - Pre-market (13:00 UTC weekdays): all 4 providers — deepseek, gemini,
//     openai, claude (rich web-search-grounded run)
//   - Intraday (13:30–15:30 UTC weekdays, every 15 min): deepseek + gemini
//     (fast snapshot-only run, lazy-fetched by /api/morning-verdict)
//   - Owner-triggered: any provider, any time (5-min rate limit per provider)
//
// `bucketAt` is floor(generatedAt, 15 min) in UTC. The unique [bucketAt,provider]
// pair lets multiple providers coexist in the same bucket and lets owner reruns
// upsert in place.
//
model MorningBriefCache {
  id             String   @id @default(cuid())
  bucketAt       DateTime
  provider       String   // 'deepseek' | 'gemini' | 'openai' | 'claude'
  htmlBody       String   @db.Text  // legacy — empty for new rows; keeps backwards compat
  verdictJson    Json?    // legacy — same row's structuredJson is preferred for the UI
  structuredJson Json?    // PRIMARY: full StructuredBrief shape consumed by the UI
  generatedAt    DateTime @default(now())
  generatedBy    String   // 'cron-premarket' | 'intraday-lazy' | 'owner-rerun:<email>'
  inputHash      String   // sha256 of snapshot.json — skip regen if unchanged
  tokensIn       Int?
  tokensOut      Int?
  costUsd        Decimal? @db.Decimal(10, 6)
  errorMsg       String?  // populated if the provider call failed (still upserts row)

  @@unique([bucketAt, provider])
  @@index([provider, bucketAt(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
}

// ── Feature 7: Daily trading journal entries ─────────────────────────────────
//
// One row per (user, entryDate). Stores the "soft" reflective layer of the
// journal — mood, sleep, market conditions, free-form notes, and links to
// charts the user wants to remember. Trades for that date stay in the Trade
// model and are joined client-side by date.
//
// Image attachments (Feature 7.2) will reuse this row by appending Vercel
// Blob URLs to `attachmentUrls` once Blob is wired. `tvLinks` is split out
// because TV chart URLs are common, lightweight, and need no storage backend.
//
model JournalEntry {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate        DateTime @db.Date  // YYYY-MM-DD, one per user per day
  moodEmoji        String?  // single grapheme like "😊" — see lib/journal/mood.ts
  sleepHours       Decimal? @db.Decimal(4, 2)  // 0.00–24.00
  marketConditions String?  // free-text or one of the enum values in lib/journal/mood.ts
  notes            String?  @db.Text
  tvLinks          Json     @default("[]")  // array of strings (TradingView or any URL)
  attachmentUrls   Json     @default("[]")  // populated by Feature 7.2 — Vercel Blob URLs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, entryDate])
  @@index([userId, entryDate(sort: Desc)])
}

// LiveQuote is upserted by external producers (moomoo daemon or Yahoo fallback
// workflow). Single row per symbol — we don't need history here (Postgres isn't
// the right store for tick history). The `source` + `observedAt` columns let
// the UI flag stale rows and decide which producer wins.
//
model LiveQuote {
  symbol     String   @id // 'SPY', 'QQQ', 'XLK', ...
  price      Decimal  @db.Decimal(12, 4)
  changePct  Decimal? @db.Decimal(8, 4)
  volume     BigInt?
  source     String   // 'moomoo' | 'yahoo'
  observedAt DateTime
  ingestedAt DateTime @default(now())

  @@index([source, observedAt(sort: Desc)])
}
